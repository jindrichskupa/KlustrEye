{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts", "index.html"],
  "exclude": [
    "node_modules",
    "out",
    "dist",
    "src-tauri",
    "backend",
    "target",
    "src/lib/prisma.ts",
    "src/lib/k8s/client.ts",
    "src/lib/k8s/resources.ts",
    "src/lib/k8s/port-forward.ts",
    "src/lib/k8s/helm.ts",
    "src/lib/ws/shell-handler.ts",
    "src/lib/ws/terminal-handler.ts",
    "server.ts",
    "src/plugins/grafana/server.ts"
  ]
}
